# IDs das planilhas de investimento no Google Sheets (acessíveis via Composio)
# Copie este arquivo para .env e preencha com seus valores

# Planilha principal de investimentos
INVEST_SPREADSHEET_ID=your_spreadsheet_id_here
INVEST_SPREADSHEET_URL=https://docs.google.com/spreadsheets/d/your_spreadsheet_id_here/edit

# Planilha de FIIs recomendados (opcional)
FIIS_RECOMENDADOS_SPREADSHEET_ID=
FIIS_RECOMENDADOS_SPREADSHEET_URL=

# Abas que o agente tem permissao de acessar (separadas por virgula)
# As demais abas serao ignoradas em qualquer operacao
SHEET_WHITELIST="Dani Carteira,Ana Carteira"

# Conexões Composio (obtidas com: composio connections list)
COMPOSIO_GOOGLESHEETS_ACCOUNT=googlesheets_xxxxx-xxxxx
COMPOSIO_GOOGLEDRIVE_ACCOUNT=

# Email de destino dos relatorios
REPORT_EMAIL=seu.email@gmail.com
